{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ingestion": {
    "SourcePath": "/data/financial-documents",
    "FileExtensions": [ ".txt", ".md" ],
    "PollingIntervalSeconds": 300,
    "SkipAlreadyIngested": true
  }
}
