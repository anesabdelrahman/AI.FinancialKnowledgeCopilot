## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Ignore Visual Studio and editor folders
.vs/
.vscode/
.idea/

# Build folders
**/[Bb]in/
**/[Oo]bj/
**/bin/
**/obj/
**/publish/

# Build results
*.dll
*.exe
*.pdb
*.apphost

# RID-specific apphost
apphost.exe

# Rider/IDE files
*.suo
*.user
*.userosscache
*.sln.docstates

# NuGet packages
*.nupkg
packages/

# Visual Studio publish folder
PublishProfiles/

# .NET Core
project.lock.json
project.assets.json
*.xproj

# Logs
*.log
[Ll]og/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# MSBuild Binary and Structured Log
*.binlog

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# OS files
.DS_Store
Thumbs.db

# Optional: user secrets
secrets.json

# Keep launchSettings.json if you need it in source control
# (do not ignore by default)